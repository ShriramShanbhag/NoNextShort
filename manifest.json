{
    "manifest_version": 3,
    "name": "StopShortsAutoplay – Stop Infinite YouTube Shorts",
    "description": "Watch one Short and stop. Avoid the infinite scroll trap on YouTube Shorts.",
    "version": "1.0",
    "permissions": ["scripting", "storage"],
    "host_permissions": ["*://www.youtube.com/*"],
    "action": {
      "default_title": "StopShortsAutoplay",
      "default_icon": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
      },
      "default_popup": "popup.html"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["*://www.youtube.com/*"],
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    ],
    "icons": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
  